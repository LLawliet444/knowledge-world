# ─── Knowledge World Docker 部署环境变量 ────────────────────────
# 复制为 apps/backend/.env 并填入真实值
# docker compose 会自动读取 apps/backend/.env 注入后端容器

# ─── OpenAI / LLM ───────────────────────────────────────────────
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-你的真实key
OPENAI_MODEL=gpt-4o-mini

# ─── Redis ──────────────────────────────────────────────────────
# docker-compose 内部网络用服务名 redis 连接
# 密码需与 docker-compose.yml 的 REDIS_PASSWORD 一致
REDIS_URL=redis://:kw_redis_dev_change_me@redis:6379/0
SESSION_TTL_SECONDS=604800

# ─── CORS 允许的前端源 ──────────────────────────────────────────
# 上线时改为你的真实域名，逗号分隔
# 例如：CORS_ORIGINS=https://kw.example.com,https://www.kw.example.com
CORS_ORIGINS=http://localhost,http://你的服务器IP

# ─── 运行环境 ───────────────────────────────────────────────────
# production：关闭 reload、关闭 /docs、Redis 无密码告警
APP_ENV=production
