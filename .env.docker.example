# ─── Knowledge World Docker 部署环境变量 ────────────────────────
# 复制为项目根目录的 .env 并填入真实值（cp .env.docker.example .env）
# docker compose 会自动读取根目录 .env，同时通过 env_file 注入 backend 容器

# ─── OpenAI / LLM ───────────────────────────────────────────────
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-你的真实key
OPENAI_MODEL=gpt-4o-mini

# ─── Redis ──────────────────────────────────────────────────────
# docker-compose 内部网络用服务名 redis 连接
# REDIS_PASSWORD 为必填项（docker-compose 启动时强制校验，无默认值）
# 生成强密码示例：openssl rand -base64 24
REDIS_PASSWORD=请替换为强密码_勿用默认值

# REDIS_URL 中的密码必须与上面的 REDIS_PASSWORD 完全一致
# docker-compose 会读取 .env 中的 REDIS_PASSWORD 注入 redis 容器
# 后端通过 REDIS_URL 连接（含密码），所以两者必须匹配
REDIS_URL=redis://:请替换为强密码_勿用默认值@redis:6379/0
SESSION_TTL_SECONDS=604800

# ─── CORS 允许的前端源 ──────────────────────────────────────────
# 上线时改为你的真实域名，逗号分隔
# 子路径部署下，前端与 API 同源（均走 https://www.fishfish.space/knowledge-world/）
# 生产环境同源请求不触发 CORS，但开发环境需要列出 localhost
CORS_ORIGINS=https://www.fishfish.space,http://localhost:5173,http://127.0.0.1:5173

# ─── 运行环境 ───────────────────────────────────────────────────
# production：关闭 reload、关闭 /docs、Redis 无密码告警
APP_ENV=production
